{
  "name": "@cardano-forge/barrow",
  "description": "Chain indexing tools for the Cardano blockchain.",
  "version": "0.0.0",
  "author": "Cardano Forge",
  "bugs": {
    "url": "https://github.com/cardano-forge/barrow/issues"
  },
  "homepage": "https://github.com/cardano-forge/barrow",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cardano-forge/barrow.git"
  },
  "keywords": [
    "javascript",
    "typescript",
    "typesafe",
    "ogmios",
    "blockchain",
    "cardano",
    "chain",
    "indexing",
    "indexer",
    "websocket",
    "web3"
  ],
  "sideEffects": false,
  "files": [
    "**"
  ],
  "main": "./index.js",
  "module": "./index.mjs",
  "types": "./index.d.mts",
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "lint": "biome check --write .",
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest",
    "pre": "npm run lint && npm run check && npm run build && npm run test",
    "exp": "dotenv -c -- tsx src/test.ts"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "require": {
        "types": "./index.d.ts",
        "require": "./index.js"
      },
      "import": {
        "types": "./index.d.mts",
        "import": "./index.mjs"
      }
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.2",
    "@cardano-ogmios/client": "^6.13.0",
    "@types/node": "^24.3.0",
    "ix": "^7.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
